{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Recurl",
  "version": "0.1.0",
  "identifier": "com.recurl.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Recurl",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "zoomHotkeysEnabled": false,
        "browserExtensionsEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
